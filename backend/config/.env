# ============================================================
# JarvisCore — Environment Configuration
# ============================================================

# --- LM Studio (local model) ---
LM_API_URL=http://100.117.165.109:1234/v1
LM_API_TOKEN=sk-lm-b9bxGsdO:zbUXc4UhCLgEMak0Qivr
LM_MODEL=lmstudio-community/Meta-Llama-3-13B-Instruct-GGUF

# --- Server ---
PORT=3001

# --- WhatsApp Bot ---
# Comma-separated list of phone numbers allowed to control the system
# Format: country code + number, NO spaces, NO dashes
# Example Argentina: 5491112345678
WHATSAPP_ALLOWED_NUMBERS=5491160597308

# --- Whisper STT (for voice messages in WhatsApp) ---
# Option A: whisper.cpp binary path (faster)
# WHISPER_CPP_PATH=C:\whisper.cpp\main.exe
# WHISPER_MODEL_PATH=C:\whisper.cpp\models\ggml-base.bin

# Option B: Python whisper (if whisper.cpp not available)
# pip install openai-whisper
# Leave blank to disable STT (voice messages will be ignored)
WHISPER_CPP_PATH=
WHISPER_MODEL_PATH=

# --- Resource limits ---
# Max CPU% before bots pause their tasks (future feature)
MAX_CPU_PERCENT=30
MAX_GPU_PERCENT=20