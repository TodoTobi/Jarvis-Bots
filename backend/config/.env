# ============================================================
# JarvisCore — Environment Configuration
# ============================================================

# --- LM Studio ---
# IP and port shown in LM Studio → Developer → "Reachable at"
LM_API_URL=http://localhost:1234/v1

# Token (from LM Studio → Developer → API Key, or leave blank)
LM_API_TOKEN=sk-lm-b9bxGsdO:zbUXc4UhCLgEMak0Qivr

# Model identifier — copy the name shown in LM Studio "Loaded Models"
# This is the EXACT string shown under the model row (e.g. meta-llama-3.1-13b-instruct-abliterated)
LM_MODEL=meta-llama-3.1-13b-instruct-abliterated

# --- Server ---
PORT=3001

# --- WhatsApp ---
# Your phone number: country code + number, NO +, NO spaces, NO dashes
# Argentina example: 5491112345678 (54 = AR code, 9 for mobile, then your number)
WHATSAPP_ALLOWED_NUMBERS=5491160597308

# --- Whisper STT for voice messages ---
# Option A: whisper.cpp (faster, recommended)
# Download from: https://github.com/ggerganov/whisper.cpp
# WHISPER_CPP_PATH=C:\whisper.cpp\main.exe
# WHISPER_MODEL_PATH=C:\whisper.cpp\models\ggml-base.bin

# Option B: Python whisper (pip install openai-whisper)
# Leave blank to disable voice transcription
WHISPER_CPP_PATH=
WHISPER_MODEL_PATH=

# --- Resource limits (future use) ---
MAX_CPU_PERCENT=30
MAX_GPU_PERCENT=20
WHATSAPP_DEBUG=false
COMPUTER_CONTROL_ENABLED=false
VISION_API_KEY=
VISION_PROVIDER=claude

