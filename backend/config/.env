# --- Vision AI (ComputerBot + VisionBot) ---
# Necesitás una API key de Anthropic para que ComputerBot funcione
# Obtené la tuya en: https://console.anthropic.com
VISION_API_KEY=
VISION_PROVIDER=claude

# ── ANDROID (ADB) ─────────────────────────────
# Android 11+: Ajustes → Opciones de desarrollador → Depuración inalámbrica
# El PUERTO correcto se muestra en esa pantalla (ej: 37125, no 5555)
ADB_PATH=C:\Users\usuario\Desktop\platform-tools\adb.exe
# ADB_PATH=/usr/local/bin/adb  ← Linux/Mac

# ── SEGURIDAD ─────────────────────────────────
# JWT_SECRET=cambia_esto_por_algo_largo_y_random

# --- Límites de recursos ---
MAX_CPU_PERCENT=30
MAX_GPU_PERCENT=20

# --- Debug ---
WHATSAPP_DEBUG=false

GOOGLE_SERVICE_ACCOUNT_PATH=./config/google_service_account.json