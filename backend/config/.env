# ============================================================
# JarvisCore — Environment Configuration
# ============================================================

# --- LM Studio ---
# IP y puerto mostrados en LM Studio → Developer → "Reachable at"
LM_API_URL=http://localhost:1234/v1

# Token (LM Studio → Developer → API Key, o dejá en blanco)
LM_API_TOKEN=sk-lm-b9bxGsdO:zbUXc4UhCLgEMak0Qivr

# Nombre del modelo — copiá el nombre exacto mostrado en LM Studio "Loaded Models"
# Dejá vacío para usar el modelo activo automáticamente
LM_MODEL=

# ── Groq API (Speech to Text) ───────────────────────────────
# Obtené tu key en: https://console.groq.com
# Modelo usado: whisper-large-v3-turbo
GROQ_API_KEY=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

# --- Servidor ---
PORT=3001

# --- WhatsApp ---
# Tu número: código de país + número, SIN +, SIN espacios, SIN guiones
# Ejemplo Argentina: 5491112345678  (54=AR, 9=celular, luego tu número)
WHATSAPP_ALLOWED_NUMBERS=5491160597308

# ── ADB (Android Debug Bridge) ──────────────────────────────
# Descargá: https://developer.android.com/studio/releases/platform-tools
# Para depuración inalámbrica (Android 11+):
#   1. Ajustes → Opciones de desarrollador → Depuración inalámbrica
#   2. El PUERTO que muestra ahí va en devices.json (adb_port)
#   3. Para conectar: adb connect IP:PUERTO
ADB_PATH=C:\platform-tools\adb.exe

# --- Control de PC (ComputerBot) ---
COMPUTER_CONTROL_ENABLED=false

# --- Vision AI (ComputerBot + VisionBot) ---
# API key de Anthropic (Claude) u OpenAI
VISION_API_KEY=
VISION_PROVIDER=claude

# --- Supabase (Historial de chat) ---
# 1. Creá un proyecto en https://supabase.com (gratis)
# 2. Ejecutá supabase_schema.sql en SQL Editor
# 3. Copiá URL y Anon Key desde Project Settings → API
SUPABASE_URL=https://eznjcwfpvrurfdydpell.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImV6bmpjd2ZwdnJ1cmZkeWRwZWxsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIxNDg0MDksImV4cCI6MjA4NzcyNDQwOX0.B_fl_d2RpE-8c2ucMfYhEXwsoUmSmxkaa7fDu1ou9CU

